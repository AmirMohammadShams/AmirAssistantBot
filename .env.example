# Exchange Configuration
EXCHANGE_ID=binance

# API Keys (leave empty for dry-run/testing)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Trading Mode
TESTNET=true

# Trading Pairs (comma-separated)
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,ADA/USDT

# Risk & Account Management
RISK_PERCENTAGE=1.0
LEVERAGE=5
MARGIN_TYPE=isolated

# EMA Filter (true to only take longs if price is near/above 200 EMA, and shorts if near/below)
USE_EMA_FILTER=true

# Telegram Settings
TELEGRAM_TOKEN=8793721062:AAFYgY2Th4tkAWIzxtCAnPmnjXnR9JW8n7Y
TELEGRAM_CHAT_ID=816086064

# Proxy (e.g. socks5h://127.0.0.1:10808)
HTTP_PROXY=socks5h://127.0.0.1:10808
